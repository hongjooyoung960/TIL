# --- Database (PostgreSQL) ---
#
# 권장: Neon(https://neon.tech) 대시보드에서 복사한 URI를 그대로 사용합니다.
# sslmode=require 가 없으면 끝에 붙이세요.
#
# Neon 예시 (값은 실제 프로젝트 것으로 교체):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
#
# 로컬 Postgres 예시:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/productivity_planner

# Absolute path to repository root (folder containing daily/, reports/, frontend/, backend/)
# Windows example: PROJECT_ROOT=C:\\work\\productivity-planner
# macOS/Linux example:
PROJECT_ROOT=/absolute/path/to/productivity-planner

# Git automation (optional)
GIT_BRANCH=main
GIT_REMOTE=origin

# Future: GitHub API token — never commit real tokens; load via env only.
# GITHUB_TOKEN=

# Browsers origins allowed for CORS (comma-separated). Production: your SPA URL(s) only,
# e.g. https://your-app.example.com (single-origin hosting is typical).
# Multiple: https://app.example.com,https://staging.example.com
CORS_ORIGINS=http://localhost:5173
